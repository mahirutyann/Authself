<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>Discord認証パネル作成サイト</title>
<style>
body, html {
    margin: 0;
    padding: 0;
    height: 100%;
    font-family: "Segoe UI", sans-serif;
    background: url('background.jpg') no-repeat center center fixed; /* 背景画像 */
    background-size: cover;
    overflow: hidden;
}

.container {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
}

.input-box {
    background: rgba(255, 255, 255, 0.9);
    border-radius: 20px; /* 角丸 */
    padding: 15px 20px;
    margin: 10px;
    width: 300px;
    max-width: 90%;
    box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    transition: all 0.3s ease;
}

input {
    width: 100%;
    border: none;
    outline: none;
    font-size: 16px;
    background: transparent;
    color: #333;
}

/* PC横長、スマホ縦長 */
@media (min-width: 768px) {
    .input-box { width: 400px; padding: 20px 30px; }
}

canvas#bubbles {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 1;
    width: 100%;
    height: 100%;
}
</style>
</head>
<body>

<canvas id="bubbles"></canvas>

<div class="container">
    <div class="input-box"><input type="text" placeholder="Bot Tokenを入力"></div>
    <div class="input-box"><input type="text" placeholder="サーバーID"></div>
    <div class="input-box"><input type="text" placeholder="チャンネルID"></div>
    <div class="input-box"><input type="text" placeholder="ロールID"></div>
</div>

<script>
// シャボン玉アニメーション
const canvas = document.getElementById('bubbles');
const ctx = canvas.getContext('2d');
canvas.width = window.innerWidth;
canvas.height = window.innerHeight;

const bubbles = [];
for(let i=0; i<50; i++){
    bubbles.push({
        x: Math.random()*canvas.width,
        y: Math.random()*canvas.height,
        radius: Math.random()*15+5,
        dx: (Math.random()-0.5)*1.5,
        dy: (Math.random()-0.5)*1.5,
        alpha: Math.random()*0.5+0.5
    });
}

function animate(){
    ctx.clearRect(0,0,canvas.width,canvas.height);
    for(const b of bubbles){
        ctx.beginPath();
        ctx.arc(b.x,b.y,b.radius,0,Math.PI*2);
        ctx.fillStyle = `rgba(173,216,230,${b.alpha})`; // 水色
        ctx.fill();
        b.x += b.dx;
        b.y += b.dy;

        if(b.x<0 || b.x>canvas.width) b.dx*=-1;
        if(b.y<0 || b.y>canvas.height) b.dy*=-1;
    }
    requestAnimationFrame(animate);
}
animate();

window.addEventListener('resize', ()=>{
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
});
</script>

</body>
</html>